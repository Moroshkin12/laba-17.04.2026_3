#TextFile2. Найдите все числа Фибоначчи с номерами от N₁ до N₂. Ответ запишите в файл с именем b.txt, располагая по одному числу в строке.
#Рекуррентное соотношение для чисел Фибоначчи:
#F₀ = 0,
#F₁ = 1,
#Fₙ = Fₙ₋₁ + Fₙ₋₂ при n > 1.


ef fibonacci(n):
    """Вычисляет n-е число Фибоначчи.

    Args:
        n (int): номер числа Фибоначчи (начиная с 0).

    Returns:
        int: значение n-го числа Фибоначчи.
    """
    if n <= 1:
        return n
    a, b = 0, 1
    for i in range(2, n + 1):
        a, b = b, a + b
    return b


def get_valid_input(prompt):
    """Запрашивает у пользователя число и проверяет его валидность.

    Args:
        prompt (str): текст запроса.

    Returns:
        int: валидное целое число.
    """
    while True:
        try:
            value = int(input(prompt))
            if value < 0:
                print("Ошибка: число должно быть неотрицательным. Попробуйте ещё раз.")
                continue
            return value
        except ValueError:
            print("Ошибка: введите целое число. Попробуйте ещё раз.")


def main():
    """Основная функция: запрашивает диапазон и записывает числа Фибоначчи в файл."""
    # Запрашиваем у пользователя границы диапазона с проверкой
    n1 = get_valid_input("Введите N1 (начальная позиция в последовательности Фибоначчи): ")
    n2 = get_valid_input("Введите N2 (конечная позиция в последовательности Фибоначчи): ")

    # Проверяем, что N2 >= N1
    if n2 < n1:
        print("Ошибка: N2 должно быть больше или равно N1. Программа завершена.")
        return

    # Пытаемся открыть файл для записи
    try:
        with open('b3.txt', 'w') as file:
            for i in range(n1, n2 + 1):
                fib_number = fibonacci(i)
                file.write(f"{fib_number}\n")
        print(f"Числа Фибоначчи с номерами от {n1} до {n2} записаны в файл 'b3.txt'")
    except IOError as e:
        print(f"Ошибка при работе с файлом: {e}. Проверьте права доступа и наличие дискового пространства.")
    except Exception as e:
        print(f"Произошла непредвиденная ошибка: {e}")


if __name__ == "__main__":
    main()
